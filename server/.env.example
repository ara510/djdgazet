# ── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Base de données PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gazety-db
DB_USER=postgres
DB_PASSWORD=ton_mot_de_passe

# ── JWT ───────────────────────────────────────────────────────────────────────
# Génère une clé forte : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_moi_en_prod

# ── Resend (emails) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ── URL publique du site (pour les liens dans les emails) ─────────────────────
APP_URL=https://gazety.mg

# ── Marque (sinon valeurs DJD par défaut) ─────────────────────────────────────
ADMIN_EMAIL_DOMAIN=@gazety.mg
SENDER_EMAIL=noreply@gazety.mg
CONTACT_EMAIL=contact@gazety.mg
BRAND_NAME=Headlines
BRAND_TAGLINE=Antananarivo, Madagascar
# BRAND_LOGO=https://gazety.mg/assets/logo.png
