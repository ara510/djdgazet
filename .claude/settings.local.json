{
  "permissions": {
    "allow": [
      "Bash(rmdir src/styles)",
      "Bash(npm install *)",
      "Bash(npm start *)",
      "Bash(tee /tmp/gazety-server.log)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} | %{size_download} bytes | %{time_total}s\\\\n\" http://localhost:4200/)",
      "Bash(curl -s http://localhost:4200/)",
      "Bash(curl -s http://localhost:4200/main.js -o /dev/null -w \"main.js: HTTP %{http_code} | %{size_download} bytes\\\\n\")",
      "Bash(curl -s http://localhost:4200/styles.css -o /dev/null -w \"styles.css: HTTP %{http_code} | %{size_download} bytes\\\\n\")",
      "Bash(echo \"Total files: $\\(find src -type f -not -path \"*/node_modules/*\")"
    ]
  }
}
